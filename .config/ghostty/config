auto-update-channel = tip

window-height = 51
window-width = 183
window-save-state = never

quick-terminal-position = center
quick-terminal-size = 75%, 75%
keybind = global:cmd+shift+O=toggle_quick_terminal

# Definição de tema
# theme = Catppuccin Mocha
# theme = TokyoNight Moon
# theme = Rose Pine Moon
theme = light:catppuccin Latte, dark:Catppuccin Macchiato
# theme = light:Catppuccin Latte, dark:Rose Pine Moon

# background-opacity = 0.1
# background-blur = macos-glass-regular

# cursor-color = #ea76cb
cursor-text = #1e66f5 

# adjust-cursor-height = 20
adjust-cursor-thickness = 3 
mouse-hide-while-typing = true
font-family = JetBrainsMono Nerd Font

macos-icon = official 
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = visible
macos-option-as-alt = right



# gtab managed include
config-file = "/Users/angelomendes/.config/gtab/ghostty-shortcut.conf"

config-file = ?auto/shader.ghostty
